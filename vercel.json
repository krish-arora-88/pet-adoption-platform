{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "^/$", "dest": "public/index.html" },
    { "src": "^/pages/(.+)$", "dest": "public/pages/$1" },
    { "src": "^/styles/(.+)$", "dest": "public/styles/$1" },
    { "src": "^/scripts/(.+)$", "dest": "public/scripts/$1" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
